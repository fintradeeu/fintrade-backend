# Database
DATABASE_URL=postgresql+asyncpg://lms_user:lms_password@postgres:5432/lms_db

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=FinTrade LMS
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# AI / OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# Milvus (optional)
MILVUS_HOST=milvus
MILVUS_PORT=19530
USE_MILVUS=false

# Email (SMTP stub)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@fittrade.com

# Redis (optional)
REDIS_URL=redis://redis:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin seed credentials
ADMIN_EMAIL=admin@platform.com
ADMIN_PASSWORD=admin123!
ADMIN_FULL_NAME=Platform Admin
